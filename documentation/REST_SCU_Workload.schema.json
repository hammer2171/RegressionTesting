{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "EPM SCU Workload",
  "type": "object",
  "required": ["runLabel", "zipFileName", "baseUrl", "notification", "audit", "retry", "operations"],
  "properties": {
    "runLabel": { "type": "string" },
    "zipFileName": { "type": "string" },
    "baseUrl": { "type": "string" },
    "folder": { "type": "string" },
    "packageKind": {
      "type": "string",
      "enum": ["OpenFormWeb", "OpenFormSV", "SaveFormWeb", "SaveFormSV", "Mixed", "Generic"]
    },
    "testName": { "type": "string" },
    "testMode": { "type": "integer", "minimum": 1 },
    "iterations": { "type": "integer", "minimum": 1 },
    "lagTime": { "type": "integer", "minimum": 0 },
    "notificationEmails": { "type": "string" },
    "workDir": { "type": "string" },
    "runsRoot": { "type": "string" },
    "notification": {
      "type": "object",
      "required": ["source", "successPattern", "failurePattern", "pollSeconds", "timeoutSeconds"],
      "properties": {
        "source": { "type": "string", "description": "UI label, API endpoint, or notification path." },
        "successPattern": { "type": "string" },
        "failurePattern": { "type": "string" },
        "pollSeconds": { "type": "integer", "minimum": 1 },
        "timeoutSeconds": { "type": "integer", "minimum": 1 },
        "escapeText": { "type": "string" }
      },
      "additionalProperties": true
    },
    "audit": {
      "type": "object",
      "required": ["endpoint", "ignoreOperations"],
      "properties": {
        "endpoint": { "type": "string" },
        "ignoreOperations": {
          "type": "array",
          "items": { "type": "string" }
        },
        "ignoreOpenForm": { "type": "boolean" },
        "downloadFileNamePattern": { "type": "string" }
      },
      "additionalProperties": true
    },
    "retry": {
      "type": "object",
      "required": ["count", "delaySeconds", "throttleMilliseconds"],
      "properties": {
        "count": { "type": "integer", "minimum": 0 },
        "delaySeconds": { "type": "integer", "minimum": 0 },
        "throttleMilliseconds": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": true
    },
    "report": {
      "type": "object",
      "properties": {
        "filenamePattern": { "type": "string" },
        "saveToRunRoot": { "type": "boolean" },
        "downloadFromInboxOnly": { "type": "boolean" }
      },
      "additionalProperties": true
    },
    "package": {
      "type": "object",
      "properties": {
        "zipFiles": {
          "type": "array",
          "items": { "type": "string" }
        },
        "allowMultipleZipFiles": { "type": "boolean" },
        "testMode3RequiresTestName": { "type": "boolean" },
        "validateZipNameOnly": { "type": "boolean" }
      },
      "additionalProperties": true
    },
    "operations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "method", "endpoint"],
        "properties": {
          "name": { "type": "string" },
          "method": { "type": "string" },
          "endpoint": { "type": "string" },
          "requestBody": {},
          "expectedStatus": { "type": "integer" },
          "nonBlocking": { "type": "boolean" },
          "throttleMilliseconds": { "type": "integer", "minimum": 0 },
          "retries": { "type": "integer", "minimum": 0 },
          "skipAudit": { "type": "boolean" },
          "skipNotification": { "type": "boolean" }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
