###############################################################################
# Normalize text files
###############################################################################

* text=auto

###############################################################################
# Scripts
###############################################################################

*.ps1 text eol=crlf
*.cmd text eol=crlf
*.bat text eol=crlf

###############################################################################
# Shell Scripts
###############################################################################

*.sh text eol=lf

###############################################################################
# Markdown
###############################################################################

*.md text eol=lf

###############################################################################
# YAML
###############################################################################

*.yml text eol=lf
*.yaml text eol=lf

###############################################################################
# JSON
###############################################################################

*.json text eol=lf

###############################################################################
# JavaScript / TypeScript
###############################################################################

*.js text eol=lf
*.ts text eol=lf

###############################################################################
# Binary Files
###############################################################################

*.zip binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.pdf binary